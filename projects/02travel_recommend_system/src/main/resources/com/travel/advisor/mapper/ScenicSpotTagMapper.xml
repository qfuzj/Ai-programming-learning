<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.travel.advisor.mapper.ScenicSpotTagMapper">


    <insert id="insertBatch" parameterType="list">
        INSERT INTO scenic_spot_tag (scenic_spot_id, tag_id, create_time)
        VALUES
        <foreach collection="list" item="item" separator=",">
            (#{item.scenicSpotId}, #{item.tagId}, #{item.createTime})
        </foreach>
    </insert>
</mapper>