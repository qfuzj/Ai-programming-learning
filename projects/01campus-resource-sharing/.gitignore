# ====================================
# IDE & 编辑器配置 (已忽略 .idea 和 .vscode)
# ====================================
.idea/
*.iml
.vscode/
*.code-workspace
# macOS 系统生成的索引文件
.DS_Store

# ====================================
# 后端 (Spring Boot / Java) 依赖与构建输出
# ====================================
# 忽略 target 文件夹
target/
build/
# 日志文件
*.log
# 运行产生的临时文件
temp/

# ====================================
# 前端 (Node.js / Vue / React) 依赖与打包
# ====================================
# 忽略 node 依赖文件夹
node_modules/
# 打包输出文件夹
dist/
# 依赖锁定文件（根据团队习惯可选）
# package-lock.json
# yarn.lock

# ====================================
# 其他本地配置
# ====================================
# 本地环境变量文件
.env
.env.local
# 上传的临时资源目录 (对应你截图中的 upload 文件夹)
upload/